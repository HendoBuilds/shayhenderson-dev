{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shayhenderson-dev",
  "compatibility_date": "2026-07-08",
  "routes": [
    { "pattern": "shayhenderson.dev", "custom_domain": true },
    { "pattern": "www.shayhenderson.dev", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
