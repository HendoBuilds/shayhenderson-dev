---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import {
  identity,
  experience,
  skillGroups,
  education,
  certifications,
  openSource,
} from '../data/profile';
---

<Base
  title="CV — Shay Henderson, Infrastructure & Cloud"
  description={`CV of ${identity.name} — ${identity.role}. ${identity.pitch}`}
  showNav={false}
>
  <div class="cv-page mx-auto max-w-[52rem] px-5 py-14 sm:px-8 sm:py-20">
    <!-- header -->
    <header class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <h1 class="display text-[clamp(2rem,5vw,2.9rem)]">{identity.name}</h1>
        <p class="mt-1 text-lg font-medium text-amber">{identity.role}</p>
      </div>
      <a href="/shay-henderson-cv.pdf" download class="btn-primary no-print text-sm">
        <Icon name="download" size={16} /> Download PDF
      </a>
    </header>

    <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-1.5">
      <li class="meta">{identity.location}</li>
      <li class="meta">
        <a href={`mailto:${identity.email}`} class="transition-colors hover:text-ink">{identity.email}</a>
      </li>
      <li class="meta">
        <a href={identity.github} class="transition-colors hover:text-ink">github.com/HendoBuilds</a>
      </li>
      <li class="meta">
        <a href={identity.linkedin} class="transition-colors hover:text-ink">linkedin.com/in/shay-henderson</a>
      </li>
    </ul>

    <p class="mt-8 max-w-[42rem] leading-relaxed text-muted">
      {`${identity.pitch} ${identity.availability}.`}
    </p>

    <!-- experience -->
    <h2 class="display mt-14 border-b border-line pb-3 text-2xl">Experience</h2>
    <div class="mt-8 space-y-10">
      {
        experience.map((job) => (
          <article>
            <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
              <h3 class="text-lg font-semibold">
                {job.title} · <span class="font-medium">{job.company}</span>
              </h3>
              <p class="meta !text-amber">{job.dates}</p>
            </div>
            <p class="meta mt-1">{job.where}</p>
            <ul class="mt-3 space-y-2">
              {job.bullets.map((b) => (
                <li class="flex gap-3 text-[0.95rem] leading-relaxed text-muted">
                  <span class="mt-[0.72em] size-1 shrink-0 rounded-full bg-line" aria-hidden="true" />
                  {b}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <!-- skills -->
    <h2 class="display mt-14 border-b border-line pb-3 text-2xl">Skills</h2>
    <dl class="mt-8 space-y-4">
      {
        skillGroups.map((group) => (
          <div class="sm:grid sm:grid-cols-[13rem_1fr] sm:gap-6">
            <dt class="text-[0.95rem] font-semibold">{group.title}</dt>
            <dd class="mt-1 text-[0.95rem] leading-relaxed text-muted sm:mt-0">{group.items.join(' · ')}</dd>
          </div>
        ))
      }
    </dl>

    <!-- education -->
    <h2 class="display mt-14 border-b border-line pb-3 text-2xl">Education & Certifications</h2>
    <ul class="mt-8 space-y-4">
      {
        [...education, ...certifications].map((e) => (
          <li class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
            <p class="text-[0.95rem] font-medium">
              {e.name} <span class="text-muted">— {e.org}</span>
            </p>
            <p class="meta">{e.dates}</p>
          </li>
        ))
      }
    </ul>
    <p class="mt-6 max-w-[42rem] text-[0.95rem] leading-relaxed text-muted">
      <span class="font-semibold text-ink">Open source: </span>{openSource}
    </p>
  </div>
</Base>
