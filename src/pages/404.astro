---
import Base from '../layouts/Base.astro';
---

<Base
  title="404 · Shay Henderson"
  description="Page not found."
  showNav={false}
>
  <div class="mx-auto flex max-w-6xl flex-col items-start px-5 py-[clamp(6rem,16vw,11rem)] sm:px-8">
    <p class="meta !text-amber">404 · not found</p>
    <h1 class="display mt-5 text-[clamp(2rem,5vw,3.4rem)]">This route doesn’t resolve.</h1>
    <a href="/" class="link-amber mt-8 text-lg font-medium">Back to the homepage</a>
  </div>
</Base>
