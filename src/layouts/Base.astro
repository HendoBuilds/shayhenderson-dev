---
import '@fontsource-variable/archivo/standard.css';
import '@fontsource-variable/martian-mono';
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { identity } from '../data/profile';

interface Props {
  title: string;
  description: string;
  showNav?: boolean;
}
const { title, description, showNav = true } = Astro.props;
---

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0a07" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, identity.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, identity.site)} />
    <meta property="og:image" content={new URL('/og.png', identity.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Shay Henderson · Infrastructure & Cloud · shayhenderson.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og.png', identity.site)} />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.dataset.theme = 'light';
      }
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="meta absolute left-4 top-4 z-50 -translate-y-20 rounded-md bg-surface-2 px-4 py-2 !text-ink transition-transform focus-visible:translate-y-0 no-print"
    >
      Skip to content
    </a>

    <header class="no-print sticky top-0 z-40 border-b border-line/60 bg-bg/85 backdrop-blur-sm">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
        <a href="/" class="meta !text-ink transition-colors hover:!text-amber">shayhenderson.dev</a>
        <div class="flex items-center gap-1 sm:gap-5">
          {showNav && (
            <nav aria-label="Sections" class="hidden items-center gap-6 md:flex">
              <a href="/#experience" class="text-sm text-muted transition-colors hover:text-ink">Experience</a>
              <a href="/#projects" class="text-sm text-muted transition-colors hover:text-ink">Projects</a>
              <a href="/#skills" class="text-sm text-muted transition-colors hover:text-ink">Skills</a>
              <a href="/#contact" class="text-sm text-muted transition-colors hover:text-ink">Contact</a>
            </nav>
          )}
          <a href="/cv" class="btn-secondary">CV</a>
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="no-print border-t border-line/60">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-5 py-8 sm:px-8">
        <p class="meta">© 2026 Shay Henderson</p>
        <p class="meta">
          Built with Astro · <a
            href="https://github.com/HendoBuilds/shayhenderson-dev"
            class="transition-colors hover:text-ink">source on GitHub</a
          >
        </p>
      </div>
    </footer>
  </body>
</html>
